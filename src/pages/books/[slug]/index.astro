---
import { getBookStaticPaths } from "../../../lib/i18n-routing";
import BookDetail from "../../../components/BookDetail.astro";

export async function getStaticPaths() {
  const paths = await getBookStaticPaths('es');
  return paths.map(p => ({ params: { slug: p.params.slug }, props: p.props }));
}

const { book, exercises } = Astro.props;
---

<BookDetail book={book} exercises={exercises} />
