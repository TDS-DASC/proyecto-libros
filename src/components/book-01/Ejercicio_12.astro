---
// Ejercicio_12.astro
const basePath = import.meta.env.BASE_URL;
---
<div>
  <div class="p-4 my-6 border border-[var(--borderEjercicio)] shadow-md rounded-md bg-[var(--cardEjercicio)]">
    <h1 class="font-semibold text-lg text-[var(--titles)] mb-4">
      🗺️ Ejercicio 12: Flujo de Agua Subterránea y Carga Hidráulica
    </h1>

    <div class="text-center mb-6">
      <img id="main-image-ej12" src={`${basePath}images/exercise12-problem.png`} alt="Diagrama del Problema 12" class="mx-auto rounded border border-gray-300 max-w-full shadow-sm" />
    </div>

    <!-- Step 1: Potentiometric contours -->
    <div id="step1-container-ej12" class="transition-all duration-300">
      <div class="p-6 bg-[var(--subtitle-bg)] rounded-md border border-[var(--borderEjercicio)] text-center">
        <h2 class="text-xl font-bold text-[var(--titles)] mb-4">
          Parte A: Líneas Equipotenciales
        </h2>
        <p class="text-[var(--titles)] mb-6 text-lg">
          Dibuja (mentalmente o en papel) las líneas equipotenciales en la unidad inferior de arena a intervalos de 1 m. El Pozo 1 está en la izquierda con carga de 36 m y el Pozo 2 en la derecha con carga de 40 m. ¿Cómo se verían?
        </p>
        <button id="btn-reveal-step1-ej12" class="bg-[#7dc6d9] hover:bg-[#3aa6b9] text-white font-bold py-2 px-6 rounded shadow transition-colors">
          Revelar Solución
        </button>
      </div>
    </div>

    <!-- Step 2: Potentiometric surface -->
    <div id="step2-container-ej12" class="mt-4 p-6 bg-[var(--subtitle-bg)] rounded-md border border-[var(--borderEjercicio)] text-center hidden transition-all duration-300">
      <h2 class="text-xl font-bold text-[var(--titles)] mb-4">
        Parte B: Superficie Potenciométrica
      </h2>
      <p class="text-[var(--titles)] mb-6 text-lg">
        Dibuja la superficie potenciométrica de la unidad inferior de arena. Conecta las elevaciones de carga (nivel del agua) en los pozos ranurados en el acuífero confinado inferior.
      </p>
      <button id="btn-reveal-step2-ej12" class="bg-[#7dc6d9] hover:bg-[#3aa6b9] text-white font-bold py-2 px-6 rounded shadow transition-colors">
        Revelar Solución
      </button>
    </div>

    <!-- Step 3: Flow direction -->
    <div id="step3-container-ej12" class="mt-4 p-6 bg-[var(--subtitle-bg)] rounded-md border border-[var(--borderEjercicio)] text-center hidden transition-all duration-300">
      <h2 class="text-xl font-bold text-[var(--titles)] mb-4">
        Parte C: Dirección del Flujo
      </h2>
      <p class="text-[var(--titles)] mb-6 text-lg">
        En el Pozo 2, la carga potenciométrica en la arena inferior es 40 m y el nivel freático en la arena superior es ~38 m. ¿Cuál es la dirección del flujo de agua subterránea a través de la unidad de arcilla superior?
      </p>
      <div class="flex justify-center gap-4 mb-4">
        <button class="flow-btn-ej12 p-3 border border-gray-300 rounded hover:bg-gray-100 transition-colors" data-ans="up">⬆️ Hacia arriba</button>
        <button class="flow-btn-ej12 p-3 border border-gray-300 rounded hover:bg-gray-100 transition-colors" data-ans="down">⬇️ Hacia abajo</button>
        <button class="flow-btn-ej12 p-3 border border-gray-300 rounded hover:bg-gray-100 transition-colors" data-ans="none">↔️ Sin flujo vertical</button>
      </div>
      <p id="step3-feedback-ej12" class="hidden font-bold text-lg mb-4"></p>
      <button id="btn-reveal-step3-ej12" class="hidden bg-[#7dc6d9] hover:bg-[#3aa6b9] text-white font-bold py-2 px-6 rounded shadow transition-colors">
        Continuar
      </button>
    </div>

    <!-- Step 4: Vertical head profile -->
    <div id="step4-container-ej12" class="mt-4 p-6 bg-[var(--subtitle-bg)] rounded-md border border-[var(--borderEjercicio)] text-center hidden transition-all duration-300">
      <h2 class="text-xl font-bold text-[var(--titles)] mb-4">
        Parte D: Perfil Vertical de Carga
      </h2>
      <p class="text-[var(--titles)] mb-6 text-lg">
        Dibuja el perfil vertical esperado de carga hidráulica cerca del Pozo 2. Recuerda: la carga disminuye ligeramente hacia abajo en el acuífero libre, luego salta hacia arriba a través del acuitardo (flujo ascendente), y es casi constante en el acuífero confinado inferior.
      </p>
      <button id="btn-reveal-step4-ej12" class="bg-[#7dc6d9] hover:bg-[#3aa6b9] text-white font-bold py-2 px-6 rounded shadow transition-colors">
        Revelar Solución Final
      </button>
    </div>
    
    <div id="final-message-ej12" class="mt-6 p-4 bg-green-50 border border-green-200 text-green-800 rounded hidden text-center font-semibold text-lg">
      ¡Has completado el Ejercicio 12! 🎉
    </div>

  </div>
</div>

<script>
  const basePath = import.meta.env.BASE_URL;
  const imgElement = document.getElementById('main-image-ej12') as HTMLImageElement;
  
  // Containers
  const step1 = document.getElementById('step1-container-ej12');
  const step2 = document.getElementById('step2-container-ej12');
  const step3 = document.getElementById('step3-container-ej12');
  const step4 = document.getElementById('step4-container-ej12');
  const finalMsg = document.getElementById('final-message-ej12');
  
  // Buttons
  const btn1 = document.getElementById('btn-reveal-step1-ej12');
  const btn2 = document.getElementById('btn-reveal-step2-ej12');
  const btn3 = document.getElementById('btn-reveal-step3-ej12');
  const btn4 = document.getElementById('btn-reveal-step4-ej12');
  const flowBtns = document.querySelectorAll('.flow-btn-ej12');
  const feedback3 = document.getElementById('step3-feedback-ej12');

  // Step 1: reveal solution image with contours (sol-1 has parts a and b)
  btn1?.addEventListener('click', () => {
    imgElement.src = `${basePath}images/exercise12-sol-1.png`;
    btn1.classList.add('hidden');
    step2?.classList.remove('hidden');
  });

  // Step 2: keep same image (already shows potentiometric surface), advance
  btn2?.addEventListener('click', () => {
    btn2.classList.add('hidden');
    step3?.classList.remove('hidden');
  });

  // Step 3: flow direction quiz — correct answer is "up"
  flowBtns.forEach(btn => {
    btn.addEventListener('click', (e) => {
      const target = e.currentTarget as HTMLButtonElement;
      const ans = target.getAttribute('data-ans');
      
      // Reset colors
      flowBtns.forEach(b => {
        b.classList.remove('bg-green-100', 'border-green-500', 'bg-red-100', 'border-red-500');
      });

      if (ans === 'up') {
        target.classList.add('bg-green-100', 'border-green-500');
        if (feedback3) {
          feedback3.textContent = "✅ ¡Correcto! El flujo es hacia arriba porque la carga potenciométrica en la arena inferior (40 m en el Pozo 2) es mayor que el nivel freático (~38 m). La presión del agua confinada es lo suficientemente alta como para forzar el agua hacia arriba a través de la arcilla.";
          feedback3.className = "text-green-600 font-bold text-lg mb-4";
          feedback3.classList.remove('hidden');
        }
        btn3?.classList.remove('hidden');
      } else {
        target.classList.add('bg-red-100', 'border-red-500');
        if (feedback3) {
          if (ans === 'down') {
            feedback3.textContent = "❌ Incorrecto. Compara la carga potenciométrica en la arena inferior con el nivel freático. En el Pozo 2, la carga inferior (40 m) es mayor que el agua superficial (~38 m), por lo que el gradiente es ascendente.";
          } else {
            feedback3.textContent = "❌ Incorrecto. Hay una diferencia de carga entre la arena inferior y el agua freática superficial, lo que genera un gradiente vertical.";
          }
          feedback3.className = "text-red-600 font-bold text-lg mb-4";
          feedback3.classList.remove('hidden');
        }
      }
    });
  });

  btn3?.addEventListener('click', () => {
    btn3.classList.add('hidden');
    // Hide flow direction buttons to clean up
    const parent = btn3.parentElement;
    if (parent) {
      const btnContainer = parent.querySelector('.flex');
      if (btnContainer) btnContainer.classList.add('hidden');
    }
    step4?.classList.remove('hidden');
  });

  btn4?.addEventListener('click', () => {
    // Show final solution image with vertical head profile (sol-2)
    imgElement.src = `${basePath}images/exercise12-sol-2.png`;
    btn4.classList.add('hidden');
    finalMsg?.classList.remove('hidden');
  });

</script>
