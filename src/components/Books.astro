---
import Layout from "../layouts/Layout.astro";
import { getCollection } from "astro:content";
import { getLangFromUrl, useTranslations } from "../i18n/utils";
import { getRelativeLocaleUrl } from 'astro:i18n';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

const books = await getCollection("books", (book) => book.data.lang === lang);
---

<Layout>
  <div class="w-full px-4 md:px-0 md:max-w-[75%] flex flex-col justify-center mt-12 md:mt-22 mx-auto">
    <div>
      <h1 class="lato-bold">{t('books.title_detail')}</h1>
      <h1 class="lato-bold text-4xl md:text-7xl mt-8">{t('books.library_title')}</h1>
      <h2 class="lato-regular text-xl w-[90%] mt-8 mb-8">
        {t('books.library_desc')}
      </h2>
    </div>
  </div>

  {
    books.map((book) => {
      const { data, id } = book;
      const { title, author, img, date, place, pages, description } = data;
      
      // Extract slug from ID (e.g., "en/book-01/index.md" -> "book-01")
      // Based on the file structure, the slug should be the directory name
      const cleanSlug = id.split('/')[1]; 

      return (
        <div class="flex flex-col md:flex-row gap-8 p-6 bg-[var(--cards)] w-full md:w-auto mx-4 md:mx-auto md:max-w-[75%] mt-8 border-t border-[var(--rayas)] rounded-md md:rounded-none">
          {/* <!-- imagen del libro --> */}
          <div>
            <a href={getRelativeLocaleUrl(lang, `books/${cleanSlug}`)}>
              <img
                src={`/proyecto-libros/${img}`}
                alt="Portada del libro"
                class="w-full md:max-w-[500px] md:max-h-[300px] h-auto rounded-sm shadow-md object-cover"
              />
            </a>
          </div>

          {/* <!-- información del libro --> */}
          <div class="flex-1 flex flex-col justify-between">
            <div>
              <h2 class="text-2xl font-bold mb-2">{title}</h2>
              <div class="flex flex-wrap gap-2 mb-4">
                <span class="px-2 py-1 text-xs text-white bg-blue-300 rounded-full">
                  {t('books.digital_education')}
                </span>
                <span class="px-2 py-1 text-xs text-blue-900 bg-blue-100 rounded-full">
                  {t('books.interactive_books')}
                </span>
                <span class="px-2 py-1 text-xs bg-blue-200 rounded-full">
                  {t('books.active_learning')}
                </span>
              </div>
              <p class="text-gray-700 mb-4 lato-regular">{description}</p>
              <ul class="text-[var(--titles)] text-sm space-y-1 mb-4">
                <li>
                  <strong>{t('books.author')}:</strong> {author}
                </li>
                <li>
                  <strong>{t('books.date')}:</strong> {date}
                </li>
                <li>
                  <strong>{t('books.place')}:</strong> {place}
                </li>
                <li>
                  <strong>{t('books.pages')}:</strong> {pages}
                </li>
              </ul>
            </div>

            {/* <!-- botones --> */}
            <div class="flex gap-3 mt-4 md:mt-0">
              <a
                href={getRelativeLocaleUrl(lang, `books/${cleanSlug}`)}
                class="bg-[var(--botonOscuro)] border border-gray-400 text-white px-4 py-2 rounded hover:bg-gray-800 transition text-center w-full md:w-auto"
              >
                {t('books.go_to_book')}
              </a>
            </div>
          </div>
        </div>
      );
    })
  }

  <!-- BOTÓN VER MÁS -->
  <div class="mt-24 mb-24 ver-mas flex justify-center">
    <a
      href={getRelativeLocaleUrl(lang, 'books')}
      class="px-6 py-2 border border-gray-400 rounded hover:bg-[var(--navfooternt)] bg-[var(--cards)] text-[var(--titles)] transition-colors duration-300 ease-in-out"
    >
      {t('books.see_more')}
    </a>
  </div>
</Layout>
